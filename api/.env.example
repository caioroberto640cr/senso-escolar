# Banco de usuários (cadastro/login). Crie um projeto grátis em https://neon.tech
# e cole aqui a "Connection string" (inclui ?sslmode=require).
DATABASE_URL=postgresql://USUARIO:SENHA@ep-xxxx.sa-east-1.aws.neon.tech/neondb?sslmode=require

# Segredo para assinar os tokens JWT. Use um valor longo e aleatório.
JWT_SECRET=troque-por-um-valor-longo-e-aleatorio
